model Profile{
    id String @id @default(uuid())
    avatar String?
    about String?

    userId String @unique
    user User @relation(fields: [userId],references: [id])
    createdA DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("profiles")
}

